# Jira (Atlassian Cloud) — gere um token em:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://hotmart.atlassian.net
JIRA_EMAIL=pedro.mello@hotmart.com
JIRA_API_TOKEN=
# JQL opcional (padrão = minhas issues não concluídas):
# JIRA_JQL=assignee = currentUser() AND statusCategory != Done ORDER BY updated DESC

# Google Calendar OAuth2 — crie em console.cloud.google.com:
#   1. Novo projeto → Ativar "Google Calendar API"
#   2. APIs & Services → Credenciais → Criar credencial → ID do cliente OAuth
#   3. Tipo: Aplicativo da Web → Adicionar URI autorizado: http://localhost:8000/api/auth/google/callback
#   4. Copiar Client ID e Client Secret abaixo
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# (preenchido automaticamente após o primeiro login em /api/auth/google)
GOOGLE_REFRESH_TOKEN=

# Fallback ICS (títulos aparecem como "Busy" em contas Workspace — use OAuth acima)
GOOGLE_CALENDAR_ICS_URL=
